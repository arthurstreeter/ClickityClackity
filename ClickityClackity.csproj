<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ClickityClackity</RootNamespace>
    <AssemblyName>ClickityClackity</AssemblyName>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <ApplicationIcon>Assets\icon_enabled.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\icon_enabled.ico"/>
    <EmbeddedResource Include="Assets\icon_disabled.ico"/>
    <EmbeddedResource Include="Assets\tray_enabled.ico"/>
    <EmbeddedResource Include="Assets\tray_disabled.ico"/>
  </ItemGroup>

</Project>
