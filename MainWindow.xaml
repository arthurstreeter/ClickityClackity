<Window x:Class="ClickityClackity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickityClackity"
        Height="640" Width="500"
        MinHeight="440" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- volume -->
            <RowDefinition Height="Auto"/>  <!-- sounds folder -->
            <RowDefinition Height="*"/>     <!-- event list -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="ClickityClackity"
                       FontSize="20" FontWeight="Bold" FontFamily="Segoe UI"
                       Foreground="{StaticResource Accent}"
                       VerticalAlignment="Center"/>
            <ToggleButton x:Name="EnableToggle"
                          DockPanel.Dock="Right"
                          Width="96" Height="28"
                          IsChecked="True"
                          Checked="EnableToggle_Checked"
                          Unchecked="EnableToggle_Unchecked">
                <TextBlock x:Name="EnableLabel" Text="● Active"
                           Foreground="{StaticResource Green}"/>
            </ToggleButton>
        </DockPanel>

        <!-- ── Volume ── -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="38"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Volume" Style="{StaticResource RowLabel}"/>
            <Slider Grid.Column="1" x:Name="VolumeSlider"
                    Minimum="0" Maximum="100" Value="80"
                    VerticalAlignment="Center"
                    ValueChanged="VolumeSlider_ValueChanged"/>
            <TextBlock Grid.Column="2" x:Name="VolumeLabel" Text="80%"
                       Style="{StaticResource RowLabel}"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- ── Sounds Folder ── -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="72"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Sounds" Style="{StaticResource RowLabel}"/>
            <TextBlock Grid.Column="1" x:Name="SoundsFolderLabel"
                       Style="{StaticResource RowLabel}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Button Grid.Column="2" Content="Browse..."
                    Padding="4,2" FontSize="11"
                    Click="BrowseSoundsFolder_Click"/>
        </Grid>

        <!-- ── Event list ── -->
        <Border Grid.Row="3"
                Background="#181825"
                BorderBrush="{StaticResource Overlay}"
                BorderThickness="1" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel x:Name="EventsPanel"/>
            </ScrollViewer>
        </Border>

        <!-- ── Footer ── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Advanced" Margin="0,0,8,0" Click="Advanced_Click"/>
            <Button Content="Open Sounds Folder" Margin="0,0,8,0" Click="OpenSoundsFolder_Click"/>
            <Button Content="Refresh" Click="RefreshSounds_Click"/>
        </StackPanel>

    </Grid>
</Window>
